{
  "name": "bolao-da-copa-2026",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "generate-sw": "node scripts/generate-sw.js",
    "dev": "npm run generate-sw && vite --port 3000",
    "dev:worker": "wrangler pages dev --compatibility-date=2024-04-01 --proxy 3000",
    "dev:all": "npm run generate-sw && concurrently --kill-others -n vite,wrangler -c cyan,yellow \"vite --port 3000\" \"wrangler pages dev --compatibility-date=2024-04-01 --proxy 3000\"",
    "build": "npm run generate-sw && vite build",
    "preview": "wrangler pages dev dist"
  },
  "dependencies": {
    "@capacitor-community/admob": "^7.2.0",
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.1",
    "@capacitor/cli": "^7.5.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/local-notifications": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.1",
    "@revenuecat/purchases-capacitor": "^13.1.5",
    "@supabase/supabase-js": "2.39.3",
    "@tailwindcss/postcss": "^4.2.1",
    "firebase": "^12.7.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.19.9",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.24",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "lucide-react": "^0.563.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "wrangler": "^4.14.4",
    "xlsx": "^0.18.5"
  }
}
